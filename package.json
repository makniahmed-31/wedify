{
  "name": "wedify",
  "version": "1.0.0",
  "private": true,
  "description": "Wedify — Tunisia's Wedding SaaS Marketplace. Monorepo: frontend (Next.js) + backend (NestJS).",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "dev:frontend:wait": "wait-on tcp:localhost:4001 && npm run dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "install:all": "npm install --prefix frontend && npm install --prefix backend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "cd backend && npx prisma migrate deploy",
    "db:studio": "cd backend && npx prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "wait-on": "^9.0.10"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}
