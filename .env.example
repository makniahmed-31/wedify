# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wedify:password@localhost:5432/wedify"
POSTGRES_USER=wedify
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:change_me@localhost:6379"
REDIS_PASSWORD=change_me_in_production

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_strong_32_char_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate_another_strong_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@wedify.tn
SMTP_PASS=your_smtp_password
SMTP_FROM="Wedify <noreply@wedify.tn>"

# ─── Storage (S3-compatible) ──────────────────────────────────────────────────
STORAGE_ENDPOINT=https://s3.example.com
STORAGE_BUCKET=wedify-media
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_REGION=eu-west-1

# ─── Payment Gateway ──────────────────────────────────────────────────────────
PAYMENT_GATEWAY_KEY=your_gateway_key
PAYMENT_GATEWAY_SECRET=your_gateway_secret

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@wedify.tn

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
